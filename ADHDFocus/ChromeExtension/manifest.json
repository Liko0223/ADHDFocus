{
  "manifest_version": 3,
  "name": "ADHD Focus — URL Blocker",
  "version": "1.0.0",
  "description": "Block distracting websites during focus sessions",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:52836/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
