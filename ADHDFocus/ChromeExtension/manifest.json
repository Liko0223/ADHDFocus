{
  "manifest_version": 3,
  "name": "ADHD Focus — URL Blocker",
  "version": "1.0.0",
  "description": "Block distracting websites during focus sessions",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "webNavigation",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
